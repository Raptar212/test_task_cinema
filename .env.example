# PostgreSQL
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# App
SECRET_KEY=replace-with-a-long-random-string-in-production
# session will expire after 24 hours
SESSION_TTL_HOURS=24
DATABASE_URL=postgresql+asyncpg://your_user:your_password@127.0.0.1:5433/your_db?ssl=disable
                    │         │         │         │    │    └─ connection parameters
                    │         │         │         │    └─ db name
                    │         │         │         └─ port
                    │         │         └─ host
                    │         └─ password
                    └─ user

APP_BASE_URL=http://localhost:8000

